# PostgreSQL
POSTGRES_DB=zytronix_db
POSTGRES_USER=your_database_user
POSTGRES_PASSWORD=your_secure_password

# API
DATABASE_URL=postgresql://your_database_user:your_secure_password@postgres:5432/zytronix_db

# Demo authentication
DEMO_ADMIN_EMAIL=admin@zytronix.online
DEMO_ADMIN_PASSWORD=change_this_password

# JWT
SECRET_KEY=replace_this_with_a_long_random_secret
